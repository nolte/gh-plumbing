{
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":enablePreCommit"
  ],
  "labels": ["chore","dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.vale\\.ini$/"],
      "matchStrings": ["nolte/vale-style/releases/download/(?<currentValue>v[0-9.]+)/"],
      "depNameTemplate": "nolte/vale-style",
      "datasourceTemplate": "github-releases"
    }
  ]
}
